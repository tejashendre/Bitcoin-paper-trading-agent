# Bitcoin Quant Trading System v3.0
# Copy this file to .env.local and fill in your values

# Upstash Redis (required)
UPSTASH_REDIS_REST_URL="your_upstash_url"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# Gemini AI (required) — pattern validation & trade reasoning
GEMINI_API_KEY="your_gemini_api_key"

# Telegram Alerts (required)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# Dashboard Auth (required) — protects all API endpoints
DASHBOARD_SECRET="choose_a_strong_secret"

# QStash Scheduling (optional — for automated trading every N minutes)
QSTASH_CURRENT_SIGNING_KEY="from_upstash_qstash_dashboard"
QSTASH_NEXT_SIGNING_KEY="from_upstash_qstash_dashboard"

# Trading Configuration
TRADING_TIMEFRAME="1h"
RISK_PER_TRADE="1"
